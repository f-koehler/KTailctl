#ifndef KTAILCTL_ICONS_TRAY_ICONS_TRAY_ICON_THEMES_HPP
#define KTAILCTL_ICONS_TRAY_ICONS_TRAY_ICON_THEMES_HPP

#include "ktailctl_config.h"
#include <QBindable>
#include <QObject>
#include <QQmlEngine>
#include <QStringList>
#include <QtQmlIntegration/qqmlintegration.h>

[[nodiscard]] inline auto trayIconThemesList() -> const QStringList &
{
    static const QStringList list = {
@KTAILCTL_TRAY_ICON_THEMES_LITERAL_LIST@
    };
    return list;
}

class TrayIconThemes : public QObject {
  Q_OBJECT
  QML_ELEMENT
  QML_SINGLETON
  Q_PROPERTY(QStringList themes READ themes CONSTANT)
  Q_PROPERTY(int currentIndex READ currentIndex WRITE setCurrentIndex BINDABLE bindableCurrentIndex NOTIFY currentIndexChanged)

  Q_SIGNALS:
    void currentIndexChanged();

  private:
    Q_OBJECT_BINDABLE_PROPERTY(TrayIconThemes, int, mCurrentIndex, &TrayIconThemes::currentIndexChanged)

  public:
    inline static TrayIconThemes *s_instance = nullptr;
    static auto create(QQmlEngine * /*engine*/, QJSEngine * /*jsEngine*/) -> TrayIconThemes * { return s_instance; }
    static void setQmlInstance(TrayIconThemes *instance) { s_instance = instance; }

    explicit TrayIconThemes(QObject *parent = nullptr) : QObject(parent) {
      mCurrentIndex = static_cast<int>(trayIconThemesList().indexOf(Config::trayIconTheme()));
      connect(Config::self(), &Config::trayIconThemeChanged, this, [this]() -> void {
        mCurrentIndex = static_cast<int>(trayIconThemesList().indexOf(Config::trayIconTheme()));
      });
    }

    [[nodiscard]] static auto themes() noexcept -> const QStringList & {
        return trayIconThemesList();
    }

    [[nodiscard]] auto currentIndex() const noexcept -> int { return mCurrentIndex; }

    void setCurrentIndex(int index) {
      if (index >= 0 && index < static_cast<int>(trayIconThemesList().size())) {
          Config::setTrayIconTheme(trayIconThemesList().at(index));
          Config::self()->save();
          mCurrentIndex = static_cast<int>(trayIconThemesList().indexOf(Config::trayIconTheme()));
      }
    }

    [[nodiscard]] auto bindableCurrentIndex() -> QBindable<int>
    {
        return {&mCurrentIndex};
    }
};

#endif
