#ifndef KTAILCTL_ICONS_TRAY_ICONS_TRAY_ICON_THEMES_HPP
#define KTAILCTL_ICONS_TRAY_ICONS_TRAY_ICON_THEMES_HPP

#include "ktailctl_config.h"
#include <QBindable>
#include <QObject>
#include <QQmlEngine>
#include <QStringList>
#include <QtQmlIntegration/qqmlintegration.h>

[[nodiscard]] inline const QStringList &trayIconThemesList()
{
    static const QStringList list = {
@KTAILCTL_TRAY_ICON_THEMES_LITERAL_LIST@
    };
    return list;
}

class TrayIconThemes : public QObject {
  Q_OBJECT
  QML_ELEMENT
  QML_SINGLETON
  Q_PROPERTY(QStringList themes READ themes CONSTANT)
  Q_PROPERTY(qsizetype currentIndex READ currentIndex WRITE setCurrentIndex BINDABLE bindableCurrentIndex NOTIFY currentIndexChanged)

  Q_SIGNALS:
    void currentIndexChanged();

  private:
    Q_OBJECT_BINDABLE_PROPERTY(TrayIconThemes, qsizetype, mCurrentIndex, &TrayIconThemes::currentIndexChanged)

  public:
    inline static TrayIconThemes *s_instance = nullptr;
    static TrayIconThemes *create(QQmlEngine *, QJSEngine *) { return s_instance; }
    static void setQmlInstance(TrayIconThemes *instance) { s_instance = instance; }

    explicit TrayIconThemes(QObject* parent = nullptr) : QObject(parent) {
      mCurrentIndex = trayIconThemesList().indexOf(Config::trayIconTheme());
      connect(Config::self(), &Config::trayIconThemeChanged, this, [this](){
      mCurrentIndex = trayIconThemesList().indexOf(Config::trayIconTheme());
      });
    }

    [[nodiscard]] const QStringList& themes() const noexcept {
        return trayIconThemesList();
    }

    [[nodiscard]] int currentIndex() const noexcept { return mCurrentIndex; }

    void setCurrentIndex(int index) {
      if(index < trayIconThemesList().size()) {
          Config::setTrayIconTheme(trayIconThemesList().at(index));
          Config::self()->save();
          mCurrentIndex = trayIconThemesList().indexOf(Config::trayIconTheme());
      }
    }

    [[nodiscard]] QBindable<int> bindableCurrentIndex()
    {
        return {&mCurrentIndex};
    }
};

#endif
